{
    "name": "wexoe/wordpress",
    "description": "Wexoe WordPress-plugins (wexoe-core + feature-plugins). Dev-verktyg: Pest + PHPCS.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload-dev": {
        "psr-4": {
            "Wexoe\\Core\\": "wexoe-core/src/",
            "Wexoe\\Tests\\Support\\": "tests/Support/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "phpcs"
    }
}
