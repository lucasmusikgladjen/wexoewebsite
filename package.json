{
  "name": "wexoe-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Wexoe monorepo — apps/builder (Next.js), apps/wordpress (WP-plugins), packages/schema (single source).",
  "scripts": {
    "schema:sync": "node tools/schema-sync.mjs",
    "schema:check": "node tools/schema-sync.mjs --check",
    "guardian": "node tools/guardian/guardian.mjs",
    "check": "node tools/schema-sync.mjs --check && node tools/guardian/guardian.mjs --check",
    "builder:dev": "npm --prefix apps/builder run dev",
    "builder:build": "npm --prefix apps/builder run build",
    "builder:lint": "npm --prefix apps/builder run lint"
  },
  "engines": {
    "node": ">=20"
  }
}
